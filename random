### Step 2 — Replace bullet list with milestone table

Add this function to `generate_contract_pdf.py`:

```python
def milestone_table(milestones_raw, styles: dict) -> list:
    """
    Render milestones as a proper table with
    Milestone, Target Date, and Notes columns.
    """
    rows = parse_milestones(milestones_raw)

    if not rows:
        return [Paragraph(
            "— Milestone schedule to be agreed and appended as Exhibit A",
            styles["missing"])]

    # Header row
    data = [[
        Paragraph("Milestone", styles["table_header"]),
        Paragraph("Target Date", styles["table_header"]),
        Paragraph("Notes", styles["table_header"]),
    ]]

    # Alternate row shading
    row_colors = []
    for i, row in enumerate(rows):
        data.append([
            Paragraph(row.get("milestone", ""), styles["table_cell"]),
            Paragraph(row.get("date", "TBD"), styles["table_cell"]),
            Paragraph(row.get("notes", "—") or "—", styles["table_cell"]),
        ])
        row_colors.append(WHITE if i % 2 == 0 else LIGHT_GREY)

    col_w = PAGE_W - 2*MARGIN
    t = Table(data, colWidths=[
        col_w * 0.45,
        col_w * 0.25,
        col_w * 0.30,
    ], repeatRows=1)

    # Build row background commands
    style_cmds = [
        ("BACKGROUND",    (0, 0), (-1, 0), BLACK_PRIMARY),
        ("GRID",          (0, 0), (-1, -1), 0.3, BORDER),
        ("LEFTPADDING",   (0, 0), (-1, -1), 8),
        ("RIGHTPADDING",  (0, 0), (-1, -1), 8),
        ("TOPPADDING",    (0, 0), (-1, -1), 6),
        ("BOTTOMPADDING", (0, 0), (-1, -1), 6),
        ("VALIGN",        (0, 0), (-1, -1), "TOP"),
        # Gold left border on milestone column
        ("LINEBEFORE",    (0, 1), (0, -1), 2, YELLOW_ACCENT),
    ]
    for i, color in enumerate(row_colors):
        style_cmds.append(("BACKGROUND", (0, i+1), (-1, i+1), color))

    t.setStyle(TableStyle(style_cmds))
    return [t]
```

